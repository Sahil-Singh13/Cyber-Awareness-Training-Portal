# Python
__pycache__/
*.pyc
venv/
env/
.venv/
.pytest_cache/
.coverage
htmlcov/

# Flask / instance data
instance/
*.db
database/*.db
database/backups/*.db
!database/backups/.gitkeep

# Logs (Version 1.0)
logs/*.log*
!logs/.gitkeep

# Uploaded user files (keep folder structure, ignore actual content)
uploads/certificates/*
!uploads/certificates/.gitkeep
uploads/photos/*
!uploads/photos/.gitkeep

# Environment variables / secrets
.env

# OS / editor junk
.DS_Store
.vscode/
*.swp
