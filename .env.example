# .env.example
# -------------
# VERSION 1.0: copy this file to ".env" (same folder as app.py) and
# fill in real values before deploying. ".env" itself is gitignored on
# purpose - never commit real secrets to source control. Every value
# below has a safe fallback baked into config.py, so the app runs fine
# in development even with no .env file at all - this file only
# matters once you're ready to move beyond local development.

# ------------------------------------------------------------------
# ENVIRONMENT
# ------------------------------------------------------------------
# Which Config class to load (see config.py): development | testing | production
APP_ENV=development

# ------------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------------
# A long, random, unpredictable string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production - app.py refuses to start with APP_ENV=production
# and the default placeholder value.
SECRET_KEY=change-this-to-a-long-random-value

# ------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------
# Defaults to a local SQLite file (database/training.db) if unset.
# Only override this if you're pointing at a different database.
# DATABASE_URL=sqlite:///database/training.db

# ------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
